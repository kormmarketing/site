{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static HTML Server (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "Live Server (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=8080", "--open=index.html"],
      "port": 8080
    }
  ]
}
